<Window x:Class="StaticCodeAnalyzer.CodeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактор кода" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Icon="Resources/icon.ico"
        Background="#2D2D2D">
    <Window.Resources>
        <SolidColorBrush x:Key="TextColor" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="AccentColor" Color="#D32F2F"/>
        <SolidColorBrush x:Key="ButtonBgGray" Color="#555"/>

        <Style x:Key="AnalyzerButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#C62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GrayButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBgGray}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Редактирование кода" FontWeight="Bold" FontSize="14" Foreground="{StaticResource AccentColor}" Margin="0,0,0,5"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource SecondaryBackground}" CornerRadius="5" Margin="0,0,5,0" Padding="5">
                <TextBox x:Name="CodeEditor" AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                         FontFamily="Consolas" FontSize="12" Background="#1E1E1E" Foreground="{StaticResource TextColor}"
                         BorderBrush="{StaticResource AccentColor}" BorderThickness="1"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource SecondaryBackground}" CornerRadius="5" Margin="5,0,0,0" Padding="5">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Ошибки и предложения" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,5"/>
                    <ListBox x:Name="IssuesListBox" Background="Transparent" Foreground="{StaticResource TextColor}"
                             BorderThickness="0" Height="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,5">
                                    <TextBlock Text="{Binding Severity}" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="5,0,0,0"/>
                                    <TextBlock Text="{Binding Suggestion}" Foreground="#AAAAAA" FontStyle="Italic" Margin="5,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="AnalyzeButton" Content="Анализ" Width="80" Height="30" Margin="0,0,10,0"
                    Click="AnalyzeButton_Click" Style="{StaticResource AnalyzerButton}"/>
            <Button x:Name="RefactorButton" Content="Рефакторинг" Width="100" Height="30" Margin="0,0,10,0"
                    Click="RefactorButton_Click" IsEnabled="False" Style="{StaticResource AnalyzerButton}"/>
            <Button x:Name="SaveButton" Content="Сохранить" Width="80" Height="30" Margin="0,0,10,0"
                    Click="SaveButton_Click" IsEnabled="False" Style="{StaticResource GrayButton}"/>
            <Button Content="Закрыть" Width="80" Height="30" Click="CloseButton_Click" Style="{StaticResource GrayButton}"/>
        </StackPanel>
    </Grid>
</Window>