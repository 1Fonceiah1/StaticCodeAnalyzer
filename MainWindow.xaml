<Window x:Class="StaticCodeAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StaticCodeAnalyzer.Models"
        Title="Статический анализатор кода"
        Icon="Resources/icon.ico"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#2D2D2D">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBackground" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="SecondaryBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="AccentColor" Color="#D32F2F"/>
        <SolidColorBrush x:Key="TextColor" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#F44336"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FF9800"/>
        <SolidColorBrush x:Key="InfoColor" Color="#2196F3"/>

        <!-- Стиль для заголовков таблицы -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Стиль для ячеек таблицы -->
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="#3D3D3D"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для строк таблицы -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource SecondaryBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <!-- Стиль для TreeViewItem: корректное выделение (белый фон, тёмный текст) -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,2"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/> <!-- убирает синюю рамку фокуса -->
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="#333333"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для CheckBox, чтобы его цвет менялся при выделении родителя и убрать синюю рамку -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/> <!-- убирает синюю рамку -->
        </Style>

        <!-- Стиль для красных кнопок -->
        <Style x:Key="AnalyzerButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#C62828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для серых кнопок (Clear) -->
        <Style x:Key="GrayButton" TargetType="Button">
            <Setter Property="Background" Value="#555"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для серого ToggleButton -->
        <Style x:Key="GrayToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#555"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#444"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с кнопками -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBackground}" CornerRadius="5" Margin="0,0,0,10" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Открыть файл" Width="100" Height="30" Margin="0,0,10,0"
                        Click="OpenFile_Click" Style="{StaticResource AnalyzerButton}"/>
                <Button Content="Открыть папку" Width="100" Height="30" Margin="0,0,10,0"
                        Click="OpenFolder_Click" Style="{StaticResource AnalyzerButton}"/>
                <Button Content="Анализировать" Width="100" Height="30" Margin="0,0,10,0"
                        Click="Analyze_Click" Style="{StaticResource AnalyzerButton}"/>
                <Button Content="Вставить код" Width="100" Height="30" Margin="0,0,10,0"
                        Click="PasteCode_Click" Style="{StaticResource AnalyzerButton}"/>
                <Button Content="Очистить" Width="100" Height="30" Margin="0,0,10,0"
                        Click="Clear_Click" Style="{StaticResource GrayButton}"/>
                <ToggleButton x:Name="ToggleTreePanel" Content="Скрыть дерево" Width="100" Height="30"
                              Checked="ToggleTreePanel_Checked" Unchecked="ToggleTreePanel_Unchecked"
                              Style="{StaticResource GrayToggleButton}"/>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: дерево файлов с чекбоксами исключения -->
            <Border Grid.Column="0" Background="{StaticResource SecondaryBackground}" CornerRadius="5" Margin="0,0,10,0" Padding="5">
                <ScrollViewer>
                    <TreeView x:Name="FilesTreeView" Background="Transparent" BorderThickness="0">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type local:FileTreeNode}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox IsChecked="{Binding IsExcluded}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>
            </Border>

            <!-- Правая панель: результаты анализа -->
            <Border Grid.Column="1" Background="{StaticResource SecondaryBackground}" CornerRadius="5" Padding="5">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Результаты анализа" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource AccentColor}" Margin="0,0,0,5"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" 
                                  Background="Transparent" Foreground="{StaticResource TextColor}"
                                  HeadersVisibility="Column" BorderThickness="0"
                                  CanUserResizeColumns="True" CanUserReorderColumns="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#3D3D3D"
                                  VerticalGridLinesBrush="Transparent"
                                  RowBackground="{StaticResource SecondaryBackground}"
                                  AlternatingRowBackground="#2A2A2A"
                                  Width="Auto">
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D32F2F"/>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Важность" Binding="{Binding Severity}" 
                                                    Width="Auto" IsReadOnly="True" MinWidth="70"/>
                                <DataGridTextColumn Header="Файл" Binding="{Binding FilePath}" 
                                                    Width="Auto" IsReadOnly="True" MinWidth="150"/>
                                <DataGridTextColumn Header="Строка" Binding="{Binding LineNumber}" 
                                                    Width="Auto" IsReadOnly="True" MinWidth="50"/>
                                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" 
                                                    Width="Auto" IsReadOnly="True" MinWidth="80"/>
                                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" 
                                                    Width="Auto" IsReadOnly="True" MinWidth="200"/>
                                <DataGridTextColumn Header="Предложение" Binding="{Binding Suggestion}" 
                                                    Width="Auto" IsReadOnly="True" MinWidth="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Строка статуса -->
        <StatusBar Grid.Row="2" Background="{StaticResource SecondaryBackground}" Margin="0,10,0,0" Padding="5">
            <TextBlock x:Name="StatusText" Foreground="{StaticResource TextColor}" Text="Готов"/>
        </StatusBar>
    </Grid>
</Window>